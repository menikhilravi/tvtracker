# Copy to .env and fill in. Only VITE_* vars are exposed to the browser.
# NOTE: never put the TMDB key here — it lives server-side in the Edge Function.

# Your Supabase project (Project Settings -> API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Where the tmdb-proxy Edge Function is reachable.
# Default is the Supabase Functions URL: {SUPABASE_URL}/functions/v1/tmdb-proxy
# Leave blank to derive it from VITE_SUPABASE_URL automatically.
VITE_TMDB_PROXY_URL=

# Web Push (episode reminders). The VAPID *public* key only — safe in the
# browser. Generate a pair with `npx web-push generate-vapid-keys` and set the
# private key as a Supabase secret (see README "Episode reminders").
# Leave blank to hide the reminders feature entirely.
VITE_VAPID_PUBLIC_KEY=
