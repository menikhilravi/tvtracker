<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_intro"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/input_supabase_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/hint_supabase_url"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:textColor="@color/ink"
            android:textColorHint="@color/faint" />

        <EditText
            android:id="@+id/input_anon_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_anon_key"
            android:importantForAutofill="no"
            android:inputType="textNoSuggestions"
            android:textColor="@color/ink"
            android:textColorHint="@color/faint" />

        <EditText
            android:id="@+id/input_app_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_app_url"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:textColor="@color/ink"
            android:textColorHint="@color/faint" />

        <EditText
            android:id="@+id/input_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_email"
            android:inputType="textEmailAddress"
            android:textColor="@color/ink"
            android:textColorHint="@color/faint" />

        <EditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:textColor="@color/ink"
            android:textColorHint="@color/faint" />

        <Button
            android:id="@+id/button_sign_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/brand"
            android:text="@string/sign_in"
            android:textColor="@color/ink" />

        <Button
            android:id="@+id/button_sync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/surface2"
            android:text="@string/sync_now"
            android:textColor="@color/ink" />

        <Button
            android:id="@+id/button_sign_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/surface2"
            android:text="@string/sign_out"
            android:textColor="@color/muted" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/muted"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
